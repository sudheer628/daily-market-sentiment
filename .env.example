# S3 output destination
OUTPUT_BUCKET=your-s3-bucket-name
OUTPUT_PREFIX=daily-market-sentiment

# News source API
SERPER_API_KEY=your-serper-api-key
SERPER_BASE_URL=

# FII/DII source tokens
APIFY_TOKEN=your-apify-token
APIFY_FII_DII_PRIMARY_DATASET_URL=
# Optional fallback dataset
APIFY_FII_DII_FALLBACK_TOKEN=
APIFY_FII_DII_FALLBACK_DATASET_URL=

# Runtime behavior
USE_MOCK=false
LOG_LEVEL=INFO

# Redis (optional) - used to store SERPER API key at key: serper_api_key
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# Email settings (Gmail example)
EMAIL_SENDER=youremail@gmail.com
EMAIL_APP_PASSWORD=your-app-password
EMAIL_RECIPIENT=recipient@example.com
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=465
